# Google Cloud API key with "Places API (New)" and "PageSpeed Insights API" enabled.
GOOGLE_MAPS_API_KEY=

# GoHighLevel Private Integration token (contacts.write scope) and sub-account location ID.
# https://marketplace.gohighlevel.com/ -> Settings -> Private Integrations
GHL_API_KEY=
GHL_LOCATION_ID=

# Public base URL of this app once deployed, used by scripts/generate-links.ts
# to build full report URLs (e.g. https://audit.yourdomain.com).
NEXT_PUBLIC_BASE_URL=http://localhost:3000
