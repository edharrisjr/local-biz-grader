# Google Maps Platform API key with "Places API (New)" enabled.
GOOGLE_MAPS_API_KEY=

# Separate Google Cloud API key restricted to "PageSpeed Insights API".
# Must be a plain API key (Credentials -> Create Credentials -> API key),
# not one created through the Maps Platform console — PageSpeed Insights
# isn't part of the Maps Platform API family and can't be added to a Maps
# Platform key's restriction list.
PAGESPEED_API_KEY=

# GoHighLevel Private Integration token (contacts.write scope) and sub-account location ID.
# https://marketplace.gohighlevel.com/ -> Settings -> Private Integrations
GHL_API_KEY=
GHL_LOCATION_ID=

# Public base URL of this app once deployed, used by scripts/generate-links.ts
# to build full report URLs (e.g. https://audit.yourdomain.com).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Serper.dev API key, used for the real Google search-rank check
# ("best {category} in {city}"). Paid per request — the result is cached
# 24h per query since the report page has no other caching. Omit to skip
# the search-ranking section entirely.
SERPER_API_KEY=

# Twilio Verify — gates the report behind an SMS code before showing
# results. All three are required together; if any is missing the gate is
# skipped entirely and the report shows unlocked (there'd otherwise be no
# way to ever unlock it). Create a Verify Service in the Twilio Console to
# get TWILIO_VERIFY_SERVICE_SID.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
